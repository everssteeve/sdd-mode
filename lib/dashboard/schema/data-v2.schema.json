{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiad.ovh/schema/data-v2.schema.json",
  "title": "AIAD SDD Dashboard Data v2",
  "description": "JSON Schema for dashboard/data.json produced by npx aiad-sdd dashboard",
  "type": "object",
  "required": ["_meta", "projet", "intents", "specs"],
  "additionalProperties": true,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["schema", "schema_version", "version", "generated"],
      "additionalProperties": true,
      "properties": {
        "schema": {
          "type": "string",
          "const": "aiad-sdd-dashboard"
        },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$"
        },
        "version": {
          "type": "string"
        },
        "generated": {
          "type": "string",
          "format": "date-time"
        },
        "slim": {
          "type": "boolean"
        }
      }
    },
    "_schema": {
      "type": "object",
      "required": ["url", "local"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string"
        },
        "local": {
          "type": "string"
        }
      }
    },
    "projet": {
      "type": "object",
      "additionalProperties": true
    },
    "intents": {
      "type": "array"
    },
    "specs": {
      "type": "array"
    },
    "gouvernance": {
      "type": "object",
      "additionalProperties": true
    },
    "facts": {
      "type": "array"
    },
    "changelog": {
      "type": "array"
    },
    "ebmAires": {
      "type": "object",
      "description": "4 aires EBM — SPEC-018-2",
      "additionalProperties": false,
      "properties": {
        "currentValue":      { "$ref": "#/$defs/aireEbm" },
        "unrealizedValue":   { "$ref": "#/$defs/aireEbm" },
        "timeToMarket":      { "$ref": "#/$defs/aireEbm" },
        "abilityToInnovate": { "$ref": "#/$defs/aireEbm" }
      }
    },
    "hillCharts": {
      "type": "object",
      "description": "Hill charts calculés depuis l'état SDD — SPEC-018-3",
      "additionalProperties": false,
      "required": ["intents", "historiqueDisponible", "messageJnsp"],
      "properties": {
        "intents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "titre", "positionX", "jnsp", "trajectoire"],
            "properties": {
              "id":         { "type": "string" },
              "titre":      { "type": "string" },
              "positionX":  { "type": "number", "minimum": 0, "maximum": 100 },
              "jnsp":       { "type": "boolean" },
              "trajectoire": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["date", "positionX"],
                  "properties": {
                    "date":      { "type": "string" },
                    "positionX": { "type": "number", "minimum": 0, "maximum": 100 }
                  }
                }
              }
            }
          }
        },
        "historiqueDisponible": { "type": "boolean" },
        "messageJnsp": { "type": ["string", "null"] }
      }
    },
    "investmentBalance": {
      "type": "object",
      "description": "Investment Balance par type d'Intent — SPEC-018-2",
      "additionalProperties": false,
      "required": ["buckets", "pcts", "total", "sante"],
      "properties": {
        "buckets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "features":   { "type": "number" },
            "enabler":    { "type": "number" },
            "conformite": { "type": "number" },
            "inconnu":    { "type": "number" }
          }
        },
        "pcts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "features":   { "type": "number" },
            "enabler":    { "type": "number" },
            "conformite": { "type": "number" },
            "inconnu":    { "type": "number" }
          }
        },
        "total": { "type": "number" },
        "sante": { "type": "string", "enum": ["ok", "attention", "critique"] }
      }
    }
  },
  "$defs": {
    "aireEbm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valeur", "label", "jnsp"],
      "properties": {
        "valeur": { "type": ["number", "null"] },
        "label":  { "type": "string" },
        "jnsp":   { "type": "boolean" }
      }
    }
  }
}
