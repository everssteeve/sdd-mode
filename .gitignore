# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*

# Build artifacts
*.tgz

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Environment
.env
.env.local

# Claude Code local settings
.claude/settings.local.json

# Playwright MCP debug artifacts (snapshots / console logs)
.playwright-mcp/

# Generated metrics files in bench scenarios
bench/**/.aiad/metrics/

# Override local des toggles de hooks (§3.13) — par machine, non versionné
.aiad/hooks-config.local.json

# Artefacts régénérés à chaque run / par session — jamais versionnés.
# (Le hook statusline les réécrit en continu : versionnés, ils re-dirtifient
#  l'arbre en permanence et bloquent tout `git checkout`.)
.aiad/.cache/
.aiad/metrics/hook-runs.jsonl
.aiad/metrics/skill-usage.jsonl
.claude/scheduled_tasks.lock

# Cache régénérable des scénarios bench (les métriques sont déjà ignorées
# ci-dessus). NB : `bench/**/dashboard/` reste VERSIONNÉ — c'est une fixture
# du test de conformité OpenAPI (#373 `brief`), pas un artefact jetable.
bench/**/.aiad/.cache/

# Scénarios bench datés (artefacts locaux de session, non versionnés)
bench/scenario-bench-*/
