{
  "name": "aiad-sdd",
  "version": "1.14.0",
  "description": "AIAD SDD Mode — Spec Driven Development pour Claude Code. Framework de développement spec-first avec agents IA.",
  "keywords": [
    "aiad",
    "sdd",
    "spec-driven-development",
    "claude-code",
    "ai-agents",
    "product-engineering",
    "spec-first",
    "context-engineering"
  ],
  "author": "Steeve Evers <evers.steeve@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everssteeve/sdd-mode.git"
  },
  "homepage": "https://aiad.ovh",
  "bin": {
    "aiad-sdd": "bin/aiad-sdd.js"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.2.0"
  },
  "type": "module",
  "scripts": {
    "test": "node --test --test-reporter=spec \"test/**/*.test.js\"",
    "test:watch": "node --test --watch \"test/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=spec --test-coverage-include='lib/**/*.js' \"test/**/*.test.js\"",
    "test:coverage:threshold": "node scripts/coverage-threshold.js",
    "lint": "node scripts/lint.js",
    "lint:deps": "node scripts/lint-deps.js",
    "lint:size": "node scripts/lint-size.js --strict",
    "lint:esm": "node scripts/lint-esm.js",
    "release": "node scripts/release.js",
    "release:dry": "node scripts/release.js patch --dry-run --skip-tests --allow-dirty",
    "mutation": "node scripts/mutation-test.js",
    "mutation:batch": "node scripts/mutation-batch.js",
    "bench:comparison": "node scripts/bench-comparison.js",
    "prepublishOnly": "npm run lint && npm run lint:deps && npm test"
  }
}
