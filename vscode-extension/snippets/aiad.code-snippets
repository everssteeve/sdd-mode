  "AIAD — squelette Intent Statement": {
    "prefix": ["aiad-skel-intent", "skel-intent"],
    "scope": "markdown",
    "body": [
      "---",
      "title: \"${1:titre intention}\"",
      "status: draft",
      "auteur: ${2:nom}",
      "date: ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      "---",
      "",
      "# INTENT-${3:001} — ${1:titre intention}",
      "",
      "## Pourquoi",
      "",
      "${4:Quel besoin métier ou utilisateur cette fonctionnalité résout-elle ?}",
      "",
      "## Conséquence si rien",
      "",
      "${5:Quel impact si on ne fait rien ?}",
      "",
      "## Frontière",
      "",
      "${6:Ce qui est inclus + ce qui N'est PAS inclus.}",
      "",
      "## Indicateur de succès",
      "",
      "${7:Comment saurons-nous que c'est réussi ?}"
    ],
    "description": "Squelette complet d'un Intent Statement (frontmatter + 4 sections)."
  },
  "AIAD — squelette SPEC EARS": {
    "prefix": ["aiad-skel-spec", "skel-spec"],
    "scope": "markdown",
    "body": [
      "---",
      "title: \"${1:titre spec}\"",
      "parent_intent: INTENT-${2:001}",
      "status: draft",
      "format: EARS",
      "governance: ${3|AIAD-RGPD,AIAD-AI-ACT,AIAD-RGAA,AIAD-RGESN,AIAD-CRA|}",
      "---",
      "",
      "# SPEC-${4:001}-${5:1}-${6:slug} — ${1:titre spec}",
      "",
      "## Contexte",
      "",
      "${7:Description du contexte technique.}",
      "",
      "## Critères d'acceptation (EARS)",
      "",
      "### R1 — ${8:premier critère}",
