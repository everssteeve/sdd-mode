{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiad.ovh/schema/verdicts/veto.schema.json",
  "title": "AIAD SDD — Verdict Veto Tier 1 (par diff)",
  "type": "object",
  "required": ["verdict", "exitCode", "triggered", "violations"],
  "properties": {
    "verdict": { "type": "string", "enum": ["PASS", "JNSP"] },
    "exitCode": { "type": "integer", "enum": [0, 2] },
    "triggered": { "type": "array", "items": { "type": "string" } },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "agent", "reason"],
        "properties": {
          "file": { "type": "string" },
          "agent": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
